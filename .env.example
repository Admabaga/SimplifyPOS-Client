# URL base del backend (incluir /api/v1)
# Desarrollo local: usar proxy de Vite o apuntar directo
VITE_API_URL=http://localhost:8000/api/v1

# En producción (Render) se configura en el panel de la app
# VITE_API_URL=https://simplifypos-api.onrender.com/api/v1

# Minutos de inactividad antes de cerrar sesión por seguridad (default 120).
# Subir/bajar según preferencia. En Render: Static Site → Environment.
VITE_IDLE_TIMEOUT_MIN=120
